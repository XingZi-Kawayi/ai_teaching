8" w:lineRule="auto"/><w:ind w:left="0"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="Consolas" w:ascii="Consolas" w:cs="Consolas" w:hAnsi="Consolas"/><w:sz w:val="22"/><w:shd w:fill="EFF0F1"/></w:rPr><w:t>""</w:t></w:r><w:r><w:rPr><w:rFonts w:eastAsia="等线" w:ascii="Arial" w:cs="Arial" w:hAnsi="Arial"/><w:sz w:val="22"/></w:rPr><w:t>：空字符串，最后兜底的方式，任意位置切分，只有前面所有分隔符切分后仍超长度时才会用。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="2"/><w:spacing w:before="320" w:after="120" w:line="288" w:lineRule="auto"/><w:ind w:left="0"/><w:jc w:val="left"/><w:outlineLvl w:val="1"/></w:pPr><w:bookmarkStart w:name="heading_10" w:id="10"/><w:r><w:rPr><w:rFonts w:eastAsia="等线" w:ascii="Arial" w:cs="Arial" w:hAnsi="Arial"/><w:b w:val="true"/><w:sz w:val="32"/></w:rPr><w:t>第五步：执行文本分割，得到分割后的文本块</w:t></w:r><w:bookmarkEnd w:id="10"/></w:p><w:p><w:pPr><w:spacing w:before="120" w:after="120" w:line="288" w:lineRule="auto"/><w:ind w:left="0"/><w:jc w:val="left"/></w:pPr><w:r><w:rPr><w:rFonts w:eastAsia="等线" w:ascii="Arial" w:cs="Arial" w:hAnsi="Arial"/><w:sz w:val="22"/></w:rPr><w:t>创建好分割器实例后，调用</w:t></w:r><w:r><w:rPr><w:rFonts w:eastAsia="Consolas" w:ascii="Consolas" w:cs="Consolas" w:hAnsi="Consolas"/><w:sz w:val="22"/><w:shd w:fill="EFF0F1"/></w:rPr><w:t>split_documents</w:t></w:r><w:r><w:rPr><w:rFonts w:eastAsia="等线" w:ascii="Arial" w:cs="Arial" w:hAnsi="Arial"/><w:sz w:val="22"/></w:rPr><w:t>方法，传入我们之前加载的文档列表</w:t></w:r><w:r><w:rPr><w:rFonts w:eastAsia="Consolas" w:ascii="Consolas" w:cs="Consolas" w:hAnsi="Consolas"/><w:sz w:val="22"/><w:shd w:fill="EFF0F1"/></w:rPr><w:t>docs</w:t></w:r><w:r><w:rPr><w:rFonts w:eastAsia="等线" w:ascii="Arial" w:cs="Arial" w:hAnsi="Arial"/><w:sz w:val="22"/></w:rPr><w:t>，就能完成分割，代码如下：</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblW w:w="0" w:type="auto"/><w:tblInd w:w="0" w:type="dxa"/><w:tblBorders><w:top w:val="single" w:color="dee0e3"/><w:left w:val="single" w:color="dee0e3"/><w:bottom w:val="single" w:color="dee0e3"/><w:right w:val="single" w:color="dee0e